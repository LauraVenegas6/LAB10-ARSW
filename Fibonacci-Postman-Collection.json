  "item": [
    {
      "name": "Fibonacci Request 1 (nth=1000000)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has a body', function () {",
              "    pm.response.to.not.be.empty;",
              "});",
              "",
              "// Registrar el resultado",
              "var timestamp = new Date().toISOString();",
              "var result = {",
              "    request: 'Request 1',",
              "    nth: 1000000,",
              "    status: pm.response.code,",
              "    responseTime: pm.response.responseTime,",
              "    timestamp: timestamp,",
              "    bodyLength: pm.response.text().length",
              "};",
              "console.log(JSON.stringify(result));",
              "",
              "if (!pm.environment.get('results')) {",
              "    pm.environment.set('results', []);",
              "}",
              "var results = JSON.parse(pm.environment.get('results') || '[]');",
              "results.push(result);",
              "pm.environment.set('results', JSON.stringify(results));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/Fibonacci?nth=1000000",
